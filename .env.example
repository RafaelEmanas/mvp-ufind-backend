# ============================================================
# ufind-backend — environment variables
# ============================================================
#
# Copy this file to the environment you want to run:
#
#   cp .env.example .env.dev
#   cp .env.example .env.prod
#
# Then fill the values accordingly.
#
# ------------------------------------------------------------
# ENVIRONMENT STRATEGY
# ------------------------------------------------------------
#
# Development:
#   Use LocalStack to mock Cloudflare R2 locally.
#   This avoids using real credentials and prevents
#   accidental writes to production storage.
#
# Production:
#   Use real Cloudflare R2 credentials.
#
# LocalStack docs:
# https://docs.localstack.cloud
#
# ============================================================


# ─────────────────────────────
# Database (Spring Boot)
# ─────────────────────────────

SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Postgres container configuration
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=


# ─────────────────────────────
# JWT
# ─────────────────────────────

JWT_SECRET=
JWT_EXPIRATION=86400000
JWT_COOKIE_NAME=token


# ─────────────────────────────
# Cloudflare R2 / S3 Storage
# ─────────────────────────────
#
# Development:
#   Use LocalStack endpoint.
#
# Production:
#   Use the real Cloudflare R2 endpoint:
#   https://<account-id>.r2.cloudflarestorage.com
#

CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_REGION=


# ─────────────────────────────
# LocalStack
# ─────────────────────────────
#
# Only required for LOCAL DEVELOPMENT.
#
# Get a token here:
# https://app.localstack.cloud
#

LOCALSTACK_AUTH_TOKEN=


# ─────────────────────────────
# Logging
# ─────────────────────────────

LOG_LEVEL=INFO