# ============================================================
# ufind-backend — development environment
#
# To start the dev environment:
#   make dev
# ============================================================

# ─────────────────────────────
# Database
# ─────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/devdb
SPRING_DATASOURCE_USERNAME=dev
SPRING_DATASOURCE_PASSWORD=dev

POSTGRES_DB=devdb
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# ─────────────────────────────
# JWT
# ─────────────────────────────

# Replace this for a new Base64 secret in production
JWT_SECRET=bXlzZWxmc3F1YXJlYmFyYnJhbmNoc29jaWFsZGlzaGxvc2VlYXJubGF3dmVzc2Vsc2Y=
JWT_EXPIRATION=86400000
JWT_COOKIE_NAME=token

# ─────────────────────────────
# Storage — RustFS (local S3 emulator)
# ─────────────────────────────
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin

CLOUDFLARE_R2_ENDPOINT=http://rustfs:9000
CLOUDFLARE_R2_ACCESS_KEY_ID=rustfsadmin
CLOUDFLARE_R2_SECRET_ACCESS_KEY=rustfsadmin
CLOUDFLARE_R2_BUCKET_NAME=ufind-dev
CLOUDFLARE_R2_REGION=us-east-1